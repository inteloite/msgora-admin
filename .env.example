# Copy this file to .env.local for local development.
# Set these same variables in your Vercel project settings.

# Vercel KV (Redis) — copy from Vercel KV dashboard → .env.local tab
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# JWT signing secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=

# License HMAC signing secret — must match the value used in the desktop app
LICENSE_SECRET=Msg@9nPw4yBz7rKe3vXt1oHs8cUfLd5jNq2mWgA6iY

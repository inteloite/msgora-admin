# Copy this file to .env.local for local development.
# Set these same variables in your Vercel project settings.

# Vercel KV (Redis) — copy from Vercel KV dashboard → .env.local tab
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# JWT signing secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=
